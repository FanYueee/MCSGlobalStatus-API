# Controller
PORT=3000
HOST=0.0.0.0
GEOIP_DIR=./data/geoip
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:3101,http://127.0.0.1:3101
HEALTH_DETAILS_WHITELIST=127.0.0.1,::1,10.0.0.0/8
CACHE_BYPASS_TOKEN=

# Public API rate limits (per IP per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_STATUS_MAX=60
RATE_LIMIT_DISTRIBUTED_MAX=20
RATE_LIMIT_WEBSOCKET_MAX=30

# Probe secrets are configured in probes.json (hot reload supported)
